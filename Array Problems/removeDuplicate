// 🔹 Two Pointer (Slow & Fast) - Remove Duplicates

// 👉 Problem:
// Remove duplicates from sorted array in-place

// 👉 Intuition:
// Since array is sorted, duplicates are adjacent

// 👉 Pointers:
// j → last unique element index (slow)
// i → iterate through array (fast)

// 👉 Logic:
// if(nums[i] != nums[j])
//     j++
//     nums[j] = nums[i]

// 👉 Return:
// j + 1 (length of unique elements)

// 👉 Time: O(n)
// 👉 Space: O(1)

// 👉 Key Idea:
// "Only move slow pointer when you find a new unique element"

class Solution {
    public int removeDuplicates(int[] nums) {
        int j=0;
        int count=1;
        for(int i=1;i<nums.length;i++){
            // if there is no duplicate
            if(nums[i]!=nums[i-1]){
                count++;
                j++;
                nums[j]=nums[i];
            }
        }
        return count;
    }
}